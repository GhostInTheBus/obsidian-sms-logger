# SMS Logger configuration
OWNER_NAME=YourName
OWNER_NUMBERS=5551234567
WEBHOOK_SECRET=change-me
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me
TIMEZONE=America/New_York
DB_PATH=/app/data/conversations.db

# Obsidian export (paths as seen inside the container)
OBSIDIAN_SMS_PATH=/vault/SMS
SMS_EXPORT_STATE_FILE=/app/data/obsidian_sms_export_state.json

# MMS attachments dir (mounted from the host)
MMS_ATTACH_DIR=/app/attachments

# Optional: AI assistant integration
# Display name used for outbound replies in the Obsidian logs
ASSISTANT_NAME=Vi
# When set, active-mode messages are relayed here and the assistant's reply is
# sent back to the sender as an SMS. Leave unset for pure logging.
#ASSISTANT_REPLY_URL=http://assistant:5067/reply
